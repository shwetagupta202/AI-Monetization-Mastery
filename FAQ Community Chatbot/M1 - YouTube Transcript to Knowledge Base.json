    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const url = $json['Video URL'] || $json.videoUrl || '';\nconst title = $json['Video Title'] || '';\nconst m = url.match(/(?:v=|\\/shorts\\/|youtu\\.be\\/|\\/embed\\/)([A-Za-z0-9_-]{11})/);\nconst videoId = m ? m[1] : '';\nreturn { json: { videoUrl: url, videoTitle: title, videoId } };"
      },
      "id": "ec004929-3f91-4fbd-b12e-28df47928072",
      "name": "Extract Video ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
