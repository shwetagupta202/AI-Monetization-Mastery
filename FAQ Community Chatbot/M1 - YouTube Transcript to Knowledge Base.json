          "name": "KIE _Amlesh"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const meta = $('Extract Video ID').item.json;\nconst r = $json;\nlet raw = '';\nif (Array.isArray(r.transcript)) raw = r.transcript.map(s => s.text || s.subtitle || '').join(' ');\nelse if (Array.isArray(r)) raw = r.map(s => s.text || '').join(' ');\nelse if (typeof r.transcript === 'string') raw = r.transcript;\nelse if (typeof r.text === 'string') raw = r.text;\nelse raw = JSON.stringify(r);\nconst clean = raw\n  .replace(/\\[\\d{1,2}:\\d{2}(:\\d{2})?\\]/g, '')\n  .replace(/\\d{1,2}:\\d{2}(:\\d{2})?/g, '')\n  .replace(/<[^>]+>/g, '')\n  .replace(/[^\\w\\s.,?!'\"-]/g, ' ')\n  .replace(/[ \\t]+/g, ' ')\n  .replace(/\\n\\s*\\n/g, '\\n')\n  .trim();\nreturn { json: { videoUrl: meta.videoUrl, videoTitle: meta.videoTitle, videoId: meta.videoId, cleanTranscript: clean } };"
      },
